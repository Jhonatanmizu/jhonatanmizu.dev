---
interface Props {
  cover: string;
  title: string;
  resume: string;
  tags: string[];
  date: string;
  slug: string;
}

const { cover, title, resume, tags, date, slug } = Astro.props;
---

<a href={`/posts/${slug}`} class="bg-gray-800 rounded-lg overflow-hidden post-card">
  <img src={cover} alt={title} class="w-full h-48 object-cover" />
  <div class="p-6">
    <div class="flex justify-between items-center mb-2">
      <div class="flex gap-2">
        {tags.map((tag) => (
          <span class="text-xs font-semibold bg-gray-700 text-white px-2 py-1 rounded">{tag}</span>
        ))}
      </div>
      <span class="text-xs text-gray-400">{date}</span>
    </div>
    <h3 class="text-xl font-bold text-white mb-2">{title}</h3>
    <p class="text-gray-300">{resume}</p>
  </div>
</a>

<style>
  .post-card {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .post-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
  }
</style>
