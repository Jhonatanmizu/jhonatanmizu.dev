---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

interface Props {
  cover: string;
  title: string;
  resume: string;
  tags: string[];
  date: string;
  slug: string;
}

const { cover, title, resume, tags, date, slug } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const postPath = lang === 'en' ? `/posts/${slug}` : `/pt/posts/${slug}`;
---

<a href={postPath} class="group bg-base_alt/50 border border-tertiary/20 rounded-xl overflow-hidden post-card flex flex-col h-full hover:border-primary/50 transition-all duration-300">
  <div class="relative overflow-hidden aspect-video">
    <img 
      src={cover} 
      alt={title} 
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" 
    />
    <div class="absolute inset-0 bg-gradient-to-t from-base_alt/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-4">
      <span class="text-xs font-medium text-primary bg-base p-2 rounded-lg">{t('posts.readMore')}</span>
    </div>
  </div>
  <div class="p-5 flex flex-col flex-grow">
    <div class="flex flex-wrap gap-2 mb-3">
      {tags.map((tag) => (
        <span class="text-[10px] uppercase tracking-wider font-bold bg-primary/10 text-primary px-2 py-0.5 rounded-full border border-primary/20">
          {tag}
        </span>
      ))}
    </div>
    <div class="flex items-center gap-2 mb-2 text-xs text-fontColor/60">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
      {date}
    </div>
    <h3 class="text-xl font-bold text-white mb-2 group-hover:text-primary transition-colors line-clamp-2">
      {title}
    </h3>
    <p class="text-sm text-fontColor/80 line-clamp-3 mb-4">
      {resume}
    </p>
  </div>
</a>

<style>
  .post-card {
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
  }
  .post-card:hover {
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
  }
</style>
