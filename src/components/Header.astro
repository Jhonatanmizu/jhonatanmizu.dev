---
const currentPath = Astro.url.pathname;
---

<header class="w-full py-6 px-6 md:px-12 sticky top-0 z-50 bg-gradient-to-b from-[#1a1f3a] to-transparent">
	<nav class="max-w-6xl mx-auto md:flex justify-between items-center">
		<div class="flex justify-between items-center">
			<div class="text-2xl font-bold text-fontColor">Jhonatanmizu.dev</div>
			<button id="menu-toggle" class="md:hidden z-50">
				<div id="hamburger-icon">
					<span></span>
					<span></span>
					<span></span>
				</div>
			</button>
		</div>
		<ul id="menu" class="hidden md:flex gap-8 text-fontColor flex-col md:flex-row md:items-center md:gap-8 absolute md:relative top-0 left-0 w-full h-screen md:h-auto bg-[#1a1f3a] md:bg-transparent justify-center md:justify-end items-center">
			<li><a href="/" class={currentPath === '/' || currentPath === '' ? 'text-primary' : 'hover:text-primary transition'}>Home</a></li>
			<li><a href="/about" class={currentPath.startsWith('/about') ? 'text-primary' : 'hover:text-primary transition'}>About</a></li>
			<li><a href="/posts" class={currentPath.startsWith('/posts') ? 'text-primary' : 'hover:text-primary transition'}>Posts</a></li>
			<li><a href="/projects" class={currentPath.startsWith('/projects') ? 'text-primary' : 'hover:text-primary transition'}>Projects</a></li>
			<li><a href="/contact" class={currentPath.startsWith('/contact') ? 'text-primary' : 'hover:text-primary transition'}>Contact</a></li>
		</ul>
	</nav>
</header>
<script>
	const menuToggle = document.getElementById('menu-toggle');
	const menu = document.getElementById('menu');
	const hamburgerIcon = document.getElementById('hamburger-icon');

	if (menuToggle && menu && hamburgerIcon) {
		menuToggle.addEventListener('click', () => {
			menu.classList.toggle('show-menu');
			hamburgerIcon.classList.toggle('is-active');
		});
	}
</script>