<section id="projects" class="w-full py-16 px-6 md:px-12">
	<div class="max-w-6xl mx-auto">
		<h2 class="text-4xl font-bold text-white mb-12">Projects</h2>
		<div class="grid md:grid-cols-2 gap-8 mb-8">
			<div class="bg-gray-700 rounded-lg p-8 hover:shadow-lg transition">
				<h3 class="text-xl font-bold text-white mb-4">Project Showcase</h3>
				<p class="text-gray-200 mb-4">
					Current projects and case studies will be displayed here showcasing my work in web development and design.
				</p>
				<div class="flex gap-2 flex-wrap">
					<span class="px-3 py-1 bg-gray-600 text-white rounded text-sm">React</span>
					<span class="px-3 py-1 bg-gray-600 text-white rounded text-sm">Design</span>
				</div>
			</div>
			<div class="bg-gray-700 rounded-lg p-8 hover:shadow-lg transition">
				<h3 class="text-xl font-bold text-white mb-4">More Projects</h3>
				<p class="text-gray-200 mb-4">
					Explore additional projects that demonstrate expertise in full-stack development and UI/UX design.
				</p>
				<div class="flex gap-2 flex-wrap">
					<span class="px-3 py-1 bg-gray-600 text-white rounded text-sm">Node.js</span>
					<span class="px-3 py-1 bg-gray-600 text-white rounded text-sm">Python</span>
				</div>
			</div>
		</div>
		<button class="w-full bg-blue-500 hover:bg-blue-600 text-white font-semibold py-3 px-6 rounded-lg transition">
			More
		</button>
	</div>
