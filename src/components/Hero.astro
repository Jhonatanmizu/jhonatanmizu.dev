---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="w-full py-20 px-6 md:px-12 text-center" data-aos="fade-up">
  <div class="max-w-6xl mx-auto">
    <h1 class="text-5xl md:text-6xl font-medium text-fontColor mb-4">
      {t('hero.title')}
    </h1>
    <p class="text-2xl font-bold md:text-2xl text-primary mb-8">
      {t('hero.subtitle')}
    </p>
    <p
      class="text-fontColor max-w-2xl mx-auto text-lg leading-relaxed md:text-justify text-left"
    >
      {t('hero.description')}
    </p>
  </div>
</section>
