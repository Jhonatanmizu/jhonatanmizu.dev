---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="w-full py-16 px-6 md:px-12" data-aos="fade-up">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-4xl font-bold text-fontColor mb-12">{t('design.title')}</h2>
    <div class="bg-gradient-to-br from-tertiary to-base rounded-lg p-8 md:p-12">
      <h3 class="text-2xl font-bold text-fontColor mb-4">{t('design.subtitle')}</h3>
      <p class="text-fontColor leading-relaxed">
        {t('design.description')}
      </p>
      <div class="mt-6 flex gap-4 flex-wrap">
        <span class="px-4 py-2 bg-base text-fontColor rounded-full text-sm"
          >Figma</span
        >
        <span class="px-4 py-2 bg-base text-fontColor rounded-full text-sm"
          >User Research</span
        >
        <span class="px-4 py-2 bg-base text-fontColor rounded-full text-sm"
          >Design Systems</span
        >
        <span class="px-4 py-2 bg-base text-fontColor rounded-full text-sm"
          >Prototyping</span
        >
        <span class="px-4 py-2 bg-base text-fontColor rounded-full text-sm"
          >Usability Testing</span
        >
        <span class="px-4 py-2 bg-base text-fontColor rounded-full text-sm"
          >Information Architecture</span
        >
      </div>
    </div>
  </div>
</section>
