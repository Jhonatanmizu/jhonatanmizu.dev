---
interface CareerItem {
  title: string;
  company: string;
  location: string;
  startDate: string;
  endDate: string;
  duration: string;
  companyLink?: string;
}

const careers: CareerItem[] = [
  {
    title: "Full Stack Engineer",
    company: "Example Tech",
    location: "São Paulo, Brazil",
    startDate: "Jan 2023",
    endDate: "Present",
    duration: "2 yrs 2 mos",
    companyLink: "https://example.com",
  },
  {
    title: "Software Developer",
    company: "Digital Solutions",
    location: "Remote",
    startDate: "Jul 2021",
    endDate: "Dec 2022",
    duration: "1 yr 5 mos",
    companyLink: "https://example.com",
  },
  {
    title: "Junior Developer",
    company: "Startup Hub",
    location: "Recife, Brazil",
    startDate: "Jun 2019",
    endDate: "Jun 2021",
    duration: "2 yrs",
    companyLink: "https://example.com",
  },
];
---

<section class="w-full py-24 px-6 md:px-12">
  <div class="max-w-6xl mx-auto">
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6">
      <div>
        <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">Professional <span class="text-primary">Journey</span></h2>
        <p class="text-fontColor/70 max-w-xl text-lg">
          My career path as a developer, focusing on building impactful products and growing within high-performing teams.
        </p>
      </div>
    </div>

    <div class="relative">
      <div class="absolute left-0 md:left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-primary/50 via-tertiary/20 to-transparent md:-translate-x-1/2"></div>
      
      <div class="space-y-12">
        {
          careers.map((career, index) => (
            <div class={`relative flex flex-col md:flex-row items-center ${index % 2 === 0 ? 'md:flex-row-reverse' : ''}`}>
              <div class="absolute left-0 md:left-1/2 w-4 h-4 bg-base border-2 border-primary rounded-full md:-translate-x-1/2 z-10 shadow-[0_0_10px_rgba(140,170,238,0.5)]"></div>
              
              <div class="w-full md:w-1/2 pl-8 md:pl-0 md:px-12">
                <div class={`bg-base_alt/40 border border-tertiary/10 p-8 rounded-2xl hover:border-primary/30 transition-all duration-300 group ${index % 2 === 0 ? 'md:text-left' : 'md:text-right'}`}>
                  <span class="text-primary font-bold text-sm mb-2 block">{career.startDate} — {career.endDate}</span>
                  <h3 class="text-2xl font-bold text-white mb-2 group-hover:text-primary transition-colors">
                    {career.title}
                  </h3>
                  <div class={`flex flex-col ${index % 2 === 0 ? 'md:items-start' : 'md:items-end'} gap-1 mb-4 text-fontColor/80`}>
                    {career.companyLink ? (
                      <a
                        href={career.companyLink}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="hover:text-primary transition font-medium flex items-center gap-1"
                      >
                        {career.company}
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2,5" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7 7 17 7 17 17"></polyline></svg>
                      </a>
                    ) : (
                      <span class="font-medium">{career.company}</span>
                    )}
                    <span class="text-xs opacity-60 uppercase tracking-widest">{career.location}</span>
                  </div>
                  <p class="text-sm text-fontColor/60 italic">{career.duration}</p>
                </div>
              </div>
              <div class="hidden md:block w-1/2"></div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
