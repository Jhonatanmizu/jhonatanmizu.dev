---
import Layout from "../../layouts/Layout.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={`${t("nav.contact")} | Jhonatan Mizu`}>
  <section
    class="w-full py-20 px-6 md:px-12 min-h-[calc(100vh-200px)] flex items-center"
  >
    <div class="max-w-4xl mx-auto w-full">
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-6xl font-bold text-white mb-6">
          {t("contact.title")}
          <span class="text-primary">{t("contact.subtitle")}</span>
        </h1>
        <p class="text-fontColor/80 text-xl max-w-2xl mx-auto leading-relaxed">
          {t("contact.description")}
        </p>
      </div>

      <div class="max-w-2xl mx-auto">
        <!-- Contact Information -->
        <div class="space-y-6" data-aos="fade-up">
          <div
            class="bg-base_alt/40 border border-tertiary/10 p-8 md:p-12 rounded-2xl h-full shadow-xl"
          >
            <h3 class="text-white font-bold text-2xl mb-8 text-center">
              {t("contact.details")}
            </h3>
            <div class="flex flex-col lg:flex-row gap-6 mb-12">
              <a
                href="mailto:jhonatanjesuss20@gmail.com"
                class="flex-1 flex items-center gap-4 text-fontColor/80 hover:text-primary transition-colors group p-4 bg-base/30 rounded-xl border border-tertiary/5 min-w-0"
              >
                <div
                  class="shrink-0 w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center text-primary group-hover:scale-110 transition-transform"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-6 h-6"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path
                      d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                    ></path><polyline points="22,6 12,13 2,6"></polyline></svg
                  >
                </div>
                <div class="min-w-0">
                  <p
                    class="text-xs font-bold uppercase tracking-wider opacity-60"
                  >
                    Email
                  </p>
                  <p class="text-lg truncate">jhonatanjesuss20@gmail.com</p>
                </div>
              </a>

              <div
                class="flex-1 flex items-center gap-4 text-fontColor/80 group p-4 bg-base/30 rounded-xl border border-tertiary/5 min-w-0"
              >
                <div
                  class="shrink-0 w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center text-primary"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-6 h-6"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"
                    ></path><circle cx="12" cy="10" r="3"></circle></svg
                  >
                </div>
                <div class="min-w-0">
                  <p
                    class="text-xs font-bold uppercase tracking-wider opacity-60"
                  >
                    {t("contact.location")}
                  </p>
                  <p class="text-lg truncate">{t("contact.locationValue")}</p>
                </div>
              </div>
            </div>

            <div class="border-t border-tertiary/10 pt-10">
              <p class="text-white font-bold mb-6 text-center">
                {t("contact.social")}
              </p>
              <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                <a
                  href="https://www.linkedin.com/in/ojhonatanjesus/"
                  target="_blank"
                  class="flex items-center justify-center gap-3 p-4 bg-base/30 rounded-xl border border-tertiary/10 hover:border-primary/50 hover:text-primary transition-all group text-sm"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-5 h-5"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path
                      d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
                    ></path><rect x="2" y="9" width="4" height="12"
                    ></rect><circle cx="4" cy="4" r="2"></circle></svg
                  >
                  <span class="font-medium">LinkedIn</span>
                </a>
                <a
                  href="https://github.com/jhonatanmizu"
                  target="_blank"
                  class="flex items-center justify-center gap-3 p-4 bg-base/30 rounded-xl border border-tertiary/10 hover:border-primary/50 hover:text-primary transition-all group text-sm"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-5 h-5"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path
                      d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"
                    ></path></svg
                  >
                  <span class="font-medium">GitHub</span>
                </a>
                <a
                  href="https://bsky.app/profile/jhonatanmizu.bsky.social"
                  target="_blank"
                  class="flex items-center justify-center gap-3 p-4 bg-base/50 rounded-xl border border-tertiary/10 hover:border-primary/50 hover:text-primary transition-all group text-sm"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-5 h-5"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    ><path
                      d="M12 10.8c-1.32-2.29-3.37-4.53-5.5-4.8-2.99-.38-5.5 1.8-5.5 5.1 0 1.28.2 2.44.8 3.36 1.15 1.76 3.1 2.2 5.1 2.2a6.4 6.4 0 0 0 4.6-1.8c.3-.3.5-.6.5-.86.15-.3.15-.6 0-.86l-.5-.86c-1.5-1.5-3.37-2.1-5.1-1.8.3-.86.8-1.5 1.5-1.8 1.32-.4 3.37 1.8 5.1 5.1 1.73-3.3 3.78-5.5 5.1-5.1.7.3 1.2.94 1.5 1.8-1.73-.3-3.6.3-5.1 1.8l-.5.86c-.15.26-.15.56 0 .86.1.26.2.56.5.86 1.3 1.3 2.9 1.8 4.6 1.8 2 0 3.95-.44 5.1-2.2.6-.92.8-2.08.8-3.36 0-3.3-2.51-5.48-5.5-5.1-2.13.27-4.18 2.51-5.5 4.8Z"
                    ></path></svg
                  >
                  <span class="font-medium">BlueSky</span>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
